---
import { getCollection } from 'astro:content';
import SandBackground from '../components/SandBackground.astro';

// Fetch the posts
const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>All Posts</title>
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&display=swap" rel="stylesheet">
    <style is:global>
      :root {
        --bg-color: #2C3E56 !important;
        --text-color: #F4F1EA !important;
        --muted-text: #A4B5C6 !important;
        --accent-white: #F4F1EA !important;
        --max-width: 650px;
      }
      body {
        background-color: var(--bg-color) !important;
        color: var(--text-color) !important;
        margin: 0;
        padding: 2rem 1.5rem 6rem 1.5rem;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        display: flex;
        justify-content: center;
      }

      /* High-contrast inverted text selection */
      ::selection {
        background-color: #F4F1EA !important;
        color: #2C3E56 !important;
        text-shadow: none !important;
      }

      ::-moz-selection {
        background-color: #F4F1EA !important;
        color: #2C3E56 !important;
        text-shadow: none !important;
      }

      main { width: 100%; max-width: var(--max-width); }
      header {
        display: flex !important;
        flex-direction: column !important;
        align-items: center !important;
        text-align: center !important;
        padding-bottom: 2.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.15);
        margin-bottom: 4rem;
        width: 100%;
      }
      header .logo { 
        font-size: 6.5rem; 
        font-family: 'EB Garamond', Georgia, serif; 
        font-weight: 500; 
        letter-spacing: -0.02em; 
        line-height: 1.1; 
        margin-bottom: 0.8rem; 
      }
      header .logo a,
      header .logo a:hover {
        color: var(--text-color) !important;
        text-decoration: none !important;
      }
      header .bio {
        color: var(--muted-text);
        font-size: 1.05rem;
        font-style: italic;
        margin: 0 0 1.5rem 0;
        max-width: 450px;
        line-height: 1.5;
      }
      header nav {
        display: flex !important;
        flex-direction: row !important;
        gap: 2rem !important;
        justify-content: center !important;
        width: 100%;
      }
      header nav a {
        color: var(--muted-text);
        text-decoration: none;
        font-size: 0.9rem;
        margin: 0 !important;
        transition: color 0.2s ease;
      }
      header nav a:hover {
        color: var(--text-color);
      }
      h1 {
        font-family: Georgia, serif;
        font-size: 3rem;
        font-weight: 400;
        margin: 0 0 0.5rem 0;
      }
      .post-count {
        color: var(--muted-text);
        font-size: 0.95rem;
        margin-bottom: 3.5rem;
      }
      .post-list {
        display: flex;
        flex-direction: column;
        gap: 2.2rem;
      }
      .post-item {
        display: flex;
        flex-direction: column;
        text-decoration: none;
        color: inherit;
        padding-left: 0.8rem;
        border-left: 2px solid transparent;
        transition: border-color 0.2s ease;
      }
      .post-item:hover {
        border-left: 2px solid var(--accent-white) !important;
      }
      .post-date {
        color: var(--muted-text);
        font-size: 0.85rem;
        margin-bottom: 0.2rem;
      }
      .post-title {
        font-size: 1.15rem;
        font-weight: 600;
        margin: 0;
      }
      .post-item:hover .post-title {
        text-decoration: none !important;
        color: var(--text-color) !important;
      }
    </style>
  </head>
  <body>
    <SandBackground />
    <main>
      <header>
        <div class="logo"><a href="/">Hadi A</a></div>
        <p class="bio"></p>
        <nav>
          <a href="https://x.com/HadiAlk4">@X</a>
          <a href="https://github.com/HadiAlk4">GitHub</a>
          <a href="https://www.linkedin.com/in/hadialkhub">LinkedIn</a>
        </nav>
      </header>

      <section>
        <h1>All Posts</h1>
        <div class="post-count">{sortedPosts.length} posts</div>

        <div class="post-list">
          {sortedPosts.map((post) => (
            <a href={`/blog/${post.slug || post.id}`} class="post-item">
              <span class="post-date">{formatDate(post.data.pubDate)}</span>
              <h2 class="post-title">{post.data.title}</h2>
            </a>
          ))}
        </div>
      </section>
    </main>
  </body>
</html>