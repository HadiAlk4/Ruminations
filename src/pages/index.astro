---
import { getCollection } from 'astro:content';

// Fetch the posts
const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>All Posts</title>
    <style>
      :root {
        --bg-color: #ffffff;
        --text-color: #111111;
        --muted-text: #888888;
        --max-width: 650px;
      }
      body {
        margin: 0;
        padding: 2rem 1.5rem 6rem 1.5rem;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background-color: var(--bg-color);
        color: var(--text-color);
        display: flex;
        justify-content: center;
      }
      main { width: 100%; max-width: var(--max-width); }
      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #eaeaea;
        margin-bottom: 4rem;
      }
      header .logo { font-size: 1.35rem; font-family: Georgia, serif; }
      header nav a { color: var(--muted-text); text-decoration: none; font-size: 0.9rem; margin-left: 1.5rem; }
      h1 { font-family: Georgia, serif; font-size: 3rem; font-weight: 400; margin: 0 0 0.5rem 0; }
      .post-count { color: var(--muted-text); font-size: 0.95rem; margin-bottom: 3.5rem; }
      .post-list { display: flex; flex-direction: column; gap: 2.2rem; }
      .post-item {
        display: flex;
        flex-direction: column;
        text-decoration: none;
        color: inherit;
        padding-left: 0.8rem;
        border-left: 2px solid transparent;
        transition: border-color 0.2s ease;
      }
      .post-item:hover {
        border-left: 2px solid var(--text-color);
      }
      .post-date { color: var(--muted-text); font-size: 0.85rem; margin-bottom: 0.2rem; }
      .post-title { font-size: 1.15rem; font-weight: 600; margin: 0; }
      .post-item:hover .post-title { text-decoration: none; }
    </style>
  </head>
  <body>
    <main>
      <header>
        <div class="logo">Hadi</div>
        <nav>
		<a href="https://github.com/HadiAlk4">GitHub</a>
        <a href="https://x.com/HadiAlk4">@HadiAlk4</a>
		<a href="www.linkedin.com/in/hadialkhub">LinkedIn</a>
        </nav>
      </header>

      <section>
        <h1>All Posts</h1>
        <div class="post-count">{sortedPosts.length} posts</div>

        <div class="post-list">
          {sortedPosts.map((post) => (
            <a href={`/blog/${post.slug || post.id}`} class="post-item">
              <span class="post-date">{formatDate(post.data.pubDate)}</span>
              <h2 class="post-title">{post.data.title}</h2>
            </a>
          ))}
        </div>
      </section>
    </main>
  </body>
</html>